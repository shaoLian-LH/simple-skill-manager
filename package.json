{
  "name": "simple-skill-manager",
  "version": "0.1.0",
  "description": "A Node.js CLI that manages skill visibility in global and project scopes.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "bin": {
    "skm": "dist/skm.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm run build:cli && pnpm run build:web",
    "build:cli": "tsup",
    "build:web": "vite build",
    "dev": "tsx src/bin/skm.ts",
    "dev:web": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run test",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm remove --global simple-skill-manager",
    "publish:verify": "pnpm run check && pnpm run build",
    "prepublishOnly": "pnpm run publish:verify"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "animate.css": "^4.1.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "gray-matter": "^4.0.3",
    "macos-open-file-dialog": "^1.0.1",
    "motion": "^12.23.24",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/compiler-sfc": "^3.5.22",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
